# Files to ignore when using git

# Protect API keys from getting public:
.env 

# Ignore markdown files in root directory only (keep docs/*.md, etc.)
/*.md

# Promptfoo (node_modules + result files)
promptfoo/node_modules/
promptfoo/*-results.json

# ignore temporary data files
.DS_Store
src/evaluation/__pycache__/*.cpython-310.pyc
# Python bytecode
__pycache__/
*.pyc

# Generated test data
data/synthetic/dialogues/*.json
data/synthetic/frozen_histories/
data/synthetic/results/*.json
experiments/

# Claude Code local settings
.claude/
src/__pycache__/
src/**/__pycache__/

# LaTeX build artifacts
thesis/build/
thesis/*.aux
thesis/*.log
thesis/*.out
thesis/*.toc
thesis/*.lof
thesis/*.lot
thesis/*.synctex.gz
thesis/*.fls
thesis/*.fdb_latexmk
thesis/*.bbl
thesis/*.blg
thesis/*.bcf
thesis/*.run.xml
thesis/*.acn
thesis/*.acr
thesis/*.alg
thesis/*.glg
thesis/*.glo
thesis/*.gls
thesis/*.ist
