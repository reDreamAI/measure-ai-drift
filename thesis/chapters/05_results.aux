\@writefile{toc}{\contentsline {subsection}{\numberline {5.6.2}Conversation Depth}{35}{subsection.5.6.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.6}{\ignorespaces Stability by conversation depth for \textsc  {Mistral~Large~3}. Jaccard is lowest at slice~2 and rises to near-ceiling values from slice~3 onward. BERTScore and alignment remain flat across depths.}}{36}{figure.caption.26}\protected@file@percent }
\newlabel{fig:slice-depth}{{5.6}{36}{Stability by conversation depth for \modelname {Mistral~Large~3}. Jaccard is lowest at slice~2 and rises to near-ceiling values from slice~3 onward. BERTScore and alignment remain flat across depths}{figure.caption.26}{}}
