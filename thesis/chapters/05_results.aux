\newlabel{chap:results}{{5}{28}{Results}{chapter.5}{}}
\@writefile{toc}{\contentsline {section}{\numberline {5.1}Plan Validity and Strategy Distribution}{28}{section.5.1}\protected@file@percent }
\newlabel{sec:res-validity}{{5.1}{28}{Plan Validity and Strategy Distribution}{section.5.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.1}{\ignorespaces Strategy distribution by model, pooled across temperatures and vignettes. Each bar shows the share of trials selecting each taxonomy category. Models with narrower distributions have less room to vary.}}{29}{figure.caption.15}\protected@file@percent }
\newlabel{fig:strategy-dist}{{5.1}{29}{Strategy distribution by model, pooled across temperatures and vignettes. Each bar shows the share of trials selecting each taxonomy category. Models with narrower distributions have less room to vary}{figure.caption.15}{}}
\@writefile{toc}{\contentsline {section}{\numberline {5.2}Plan Consistency (Method 1)}{29}{section.5.2}\protected@file@percent }
\newlabel{sec:res-plan-consistency}{{5.2}{29}{Plan Consistency (Method 1)}{section.5.2}{}}
\@writefile{toc}{\contentsline {paragraph}{\nonumberline Proprietary models are temperature-immune.}{29}{paragraph*.18}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{\nonumberline Most open-weight models peak at low temperatures.}{29}{paragraph*.19}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.2}{\ignorespaces Mean Jaccard similarity by model and temperature, grouped by family. Shaded bands show $\pm 1$ SD across vignettes. The dashed line marks the random baseline ($J \approx 0.2$). Higher is more consistent.}}{30}{figure.caption.16}\protected@file@percent }
\newlabel{fig:jaccard}{{5.2}{30}{Mean Jaccard similarity by model and temperature, grouped by family. Shaded bands show $\pm 1$ SD across vignettes. The dashed line marks the random baseline ($J \approx 0.2$). Higher is more consistent}{figure.caption.16}{}}
\@writefile{toc}{\contentsline {paragraph}{\nonumberline Greedy decoding is not always optimal.}{30}{paragraph*.20}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{\nonumberline Temperature sensitivity varies by model.}{30}{paragraph*.21}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.3}{\ignorespaces Modal-set agreement by model and temperature. The agreement rate is the proportion of trials selecting the most common strategy combination per condition. Models with agreement near 1.0 select the same strategy pair on nearly every trial.}}{31}{figure.caption.17}\protected@file@percent }
\newlabel{fig:modal}{{5.3}{31}{Modal-set agreement by model and temperature. The agreement rate is the proportion of trials selecting the most common strategy combination per condition. Models with agreement near 1.0 select the same strategy pair on nearly every trial}{figure.caption.17}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.1}{\ignorespaces Spearman correlation between Jaccard and temperature, per model. Significant correlations ($p < 0.05$) are marked with an asterisk.}}{31}{table.caption.22}\protected@file@percent }
\newlabel{tab:temp-spearman}{{5.1}{31}{Spearman correlation between Jaccard and temperature, per model. Significant correlations ($p < 0.05$) are marked with an asterisk}{table.caption.22}{}}
\@writefile{toc}{\contentsline {section}{\numberline {5.3}Response Similarity (Method 2)}{32}{section.5.3}\protected@file@percent }
\newlabel{sec:res-similarity}{{5.3}{32}{Response Similarity (Method 2)}{section.5.3}{}}
\@writefile{toc}{\contentsline {section}{\numberline {5.4}Plan-Response Alignment (Method 3)}{32}{section.5.4}\protected@file@percent }
\newlabel{sec:res-alignment}{{5.4}{32}{Plan-Response Alignment (Method 3)}{section.5.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.4}{\ignorespaces Plan-response alignment by temperature (left) and overall by model (right). Error bars show $\pm 1$ SD. Most models implement their declared strategies consistently regardless of temperature.}}{33}{figure.caption.23}\protected@file@percent }
\newlabel{fig:alignment}{{5.4}{33}{Plan-response alignment by temperature (left) and overall by model (right). Error bars show $\pm 1$ SD. Most models implement their declared strategies consistently regardless of temperature}{figure.caption.23}{}}
\@writefile{toc}{\contentsline {section}{\numberline {5.5}Cross-Method Analysis}{33}{section.5.5}\protected@file@percent }
\newlabel{sec:res-cross}{{5.5}{33}{Cross-Method Analysis}{section.5.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.2}{\ignorespaces Spearman correlations between the three evaluation methods. All correlations are significant ($p < 0.001$). The moderate Jaccard--BERTScore correlation and weak Jaccard--Alignment correlation confirm that the methods capture distinct dimensions.}}{34}{table.caption.24}\protected@file@percent }
\newlabel{tab:cross-corr}{{5.2}{34}{Spearman correlations between the three evaluation methods. All correlations are significant ($p < 0.001$). The moderate Jaccard--BERTScore correlation and weak Jaccard--Alignment correlation confirm that the methods capture distinct dimensions}{table.caption.24}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.5}{\ignorespaces Strategy consistency (median Jaccard) versus semantic consistency (mean BERTScore F1) per model, pooled across temperatures. The proprietary models cluster in the upper-right corner. \textsc  {Qwen~3.5~27B} and \textsc  {Mistral~Small~4} occupy opposite ends of the BERTScore axis despite similar Jaccard ranges.}}{34}{figure.caption.25}\protected@file@percent }
\newlabel{fig:correlations}{{5.5}{34}{Strategy consistency (median Jaccard) versus semantic consistency (mean BERTScore F1) per model, pooled across temperatures. The proprietary models cluster in the upper-right corner. \modelname {Qwen~3.5~27B} and \modelname {Mistral~Small~4} occupy opposite ends of the BERTScore axis despite similar Jaccard ranges}{figure.caption.25}{}}
\@writefile{toc}{\contentsline {section}{\numberline {5.6}Secondary Effects}{35}{section.5.6}\protected@file@percent }
\newlabel{sec:res-secondary}{{5.6}{35}{Secondary Effects}{section.5.6}{}}
